{
  "manifest_version": 3,
  "name": "TeamCheck para WhatsApp Web",
  "version": "7.1.0",
  "description": "Veja a ficha do cliente do TeamCheck direto no WhatsApp Web — Jordan Representações. Usa sua sessão já aberta (sem login).",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://*.jordanmt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}